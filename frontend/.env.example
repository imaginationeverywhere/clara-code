NEXT_PUBLIC_SITE_URL=https://claracode.ai

# Clerk Authentication
# Add these to CF Pages → Settings → Environment Variables (encrypted)
# Without them, middleware is a passthrough and /dashboard is unprotected.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:3031/graphql

# GA4 (build-time public ID; Measurement Protocol secret is backend-only)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Hermes gateway (server-side only; used by src/app/api/voice/chat/route.ts)
HERMES_GATEWAY_URL=https://info-24346--hermes-gateway.modal.run

# Stripe (test keys from SSM: /clara-code/test/STRIPE_PUBLISHABLE_KEY and /clara-code/test/STRIPE_SECRET_KEY)
# pk_test_ is baked into the client bundle at build time — must be present during `npm run pages:build`
# sk_test_ is runtime-only — set as wrangler secret, never in client bundle
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
