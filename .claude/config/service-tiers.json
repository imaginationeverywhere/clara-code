  "ipBuilding": {
    "description": "How custom work builds reusable IP",
    "process": {
      "1_fullCustomClient": {
        "action": "Client pays for custom pattern definition",
        "cost": "Included in full-custom pricing",
        "ownership": "Quik Nation owns pattern, client owns their implementation"
      },
      "2_patternExtraction": {
        "action": "Pattern added to pattern-mappings.json",
        "includes": ["Agent chain", "Skill mapping", "Feature list", "Timeline", "Pricing"]
      },
      "3_futureClients": {
        "action": "Similar clients use pre-built pattern",
        "pricing": "Template tier pricing (lower cost, higher margin)",
        "benefit": "80% less work, same or better margins"
      }
    },
    "revenueModel": {
      "firstClient": "Full custom pricing (pattern development funded)",
      "subsequentClients": "Template pricing (pure profit)",
      "verticalOwnership": "Become the expert in that industry vertical"
    },
    "examples": [
      {
        "pattern": "construction",
        "firstClient": "Pink Collar Contractors - $75,000",
        "secondClient": "QuikAction - $35,000 (pattern reuse)",
        "margin": "80% less development effort"
      },
      {
        "pattern": "nonprofit",
        "firstClient": "G Code Systems - $60,000",
        "futureClients": "Other nonprofits - $30,000",
        "verticalValue": "Nonprofit management vertical owned"
      }
