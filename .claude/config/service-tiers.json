        },
        "standard": {
          "price": 3500,
          "deliveryDays": 10,
          "includes": ["2 discovery calls", "PRD document", "User personas", "2 revisions"]
        },
        "comprehensive": {
          "price": 7500,
          "deliveryDays": 15,
          "includes": ["Unlimited calls", "Full PRD", "Personas", "Technical arch", "Unlimited revisions"]
        }
      }
    },

    "designService": {
      "displayName": "Magic Patterns Design Service",
