          "deliveryDays": 30,
          "includes": ["Web + Mobile designs", "Design system", "Responsive", "Unlimited revisions"]
        }
      }
    },

    "patternDefinition": {
      "displayName": "Custom Pattern Definition",
      "description": "Define new agent/skill matching for unique business types",
      "availability": ["guided-custom"],
      "pricing": {
        "adaptation": {
          "price": 1500,
          "deliveryDays": 3,
          "includes": ["Modify existing pattern", "Add/remove agents", "Documentation"]
        },
        "newPattern": {
          "price": 5000,
          "deliveryDays": 7,
          "includes": ["Full pattern definition", "Agent chain", "Skill mapping", "Schema design", "MASTER_TASKS template"]
        },
        "complexPattern": {
