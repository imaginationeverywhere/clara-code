{
  "$schema": "./service-tiers.schema.json",
  "version": "1.0.0",
  "lastUpdated": "2025-12-24",
  "description": "Revenue model and service tier configuration for Quik Nation AI",

  "serviceTiers": {

    "self-service": {
      "displayName": "Self-Service (Template-Based)",
      "description": "Client uses existing PRD template and pre-built mockup patterns",
      "targetClient": "Small businesses, startups with clear requirements",
      "deliveryTime": "30-45 days",

      "included": {
        "prd": {
          "type": "template",
          "source": "docs/prd-templates/{industry}.md",
          "customization": "client-fills-placeholders",
          "support": "documentation-only"
        },
        "design": {
          "type": "template",
          "source": "templates/{pattern}/",
          "customization": "colors-and-branding-only",
          "support": "none"
        },
        "patternDefinition": {
          "type": "pre-defined",
          "source": "pattern-mappings.json",
          "customization": "none"
        },
        "development": {
          "type": "agent-execution",
          "humanOversight": "minimal",
          "revisionRounds": 2
        }
      },

      "pricing": {
        "model": "fixed",
        "range": {
          "min": 15000,
          "max": 35000
        },
        "factors": ["pattern-complexity", "feature-count"]
      },

      "recurring": {
        "hosting": {
          "min": 99,
          "max": 299,
          "period": "monthly"
        },
        "support": {
          "min": 0,
          "max": 199,
          "period": "monthly",
          "note": "Email support included, priority support extra"
        },
        "transactionFees": {
          "percentage": 0.5,
          "note": "Platform fee on Stripe Connect transactions"
        }
      },

      "requirements": {
        "clientProvides": [
          "Completed PRD template with all placeholders filled",
          "Brand assets (logo, colors, fonts)",
          "Content (product data, service descriptions, etc.)",
          "Stripe account",
          "Domain name"
        ],
        "quikNationProvides": [
          "Template-based mockup",
          "Auto Claude implementation",
          "AWS infrastructure",
          "Deployment",
          "30-day bug fixes"
        ]
      }
    },

    "guided-custom": {
      "displayName": "Guided Custom",
      "description": "Customized PRD and Magic Patterns design with existing pattern",
      "targetClient": "Growing businesses needing unique branding and UX",
      "deliveryTime": "45-75 days",

      "included": {
        "prd": {
          "type": "guided-creation",
          "source": "discovery-session",
          "customization": "full",
          "support": "2-hour-discovery-call",
          "billable": true,
          "price": {
            "min": 1500,
            "max": 5000
          }
        },
        "design": {
          "type": "magic-patterns-custom",
          "source": "design-team-creates",
          "customization": "full",
          "support": "3-revision-rounds",
          "billable": true,
          "price": {
            "min": 2500,
            "max": 15000
          }
        },
        "patternDefinition": {
          "type": "pre-defined-with-modifications",
          "source": "pattern-mappings.json",
          "customization": "agent-skill-additions"
        },
        "development": {
          "type": "agent-with-oversight",
          "humanOversight": "regular",
          "revisionRounds": 3
        }
      },

      "pricing": {
        "model": "itemized",
        "components": {
          "discovery": {
            "min": 1500,
            "max": 5000
          },
          "design": {
            "min": 2500,
            "max": 15000
          },
          "development": {
            "min": 25000,
            "max": 60000
          }
        },
        "totalRange": {
          "min": 29000,
          "max": 80000
        }
      },

      "recurring": {
        "hosting": {
          "min": 199,
          "max": 499,
          "period": "monthly"
        },
        "support": {
          "min": 199,
          "max": 499,
          "period": "monthly",
          "note": "Priority support with SLA"
        },
        "transactionFees": {
          "percentage": 0.5,
          "note": "Platform fee on Stripe Connect transactions"
        }
      },

      "requirements": {
        "clientProvides": [
          "Business requirements (we help refine)",
          "Brand assets (logo, colors, fonts)",
          "Content (product data, service descriptions, etc.)",
          "Stripe account",
          "Domain name",
          "Availability for discovery sessions"
        ],
        "quikNationProvides": [
          "PRD discovery and creation",
          "Custom Magic Patterns design",
          "Pattern adaptation",
          "Auto Claude implementation with oversight",
          "AWS infrastructure",
          "Deployment",
          "60-day bug fixes",
          "Training session"
        ]
      }
    },

    "full-custom": {
      "displayName": "Full Custom (Premium)",
      "description": "Complete custom PRD, design, pattern definition, and white-glove implementation",
      "targetClient": "Enterprises, unique business models, complex requirements",
      "deliveryTime": "90-180 days",

      "included": {
        "prd": {
          "type": "custom-from-scratch",
          "source": "discovery-workshops",
          "customization": "full",
          "support": "unlimited-discovery",
          "billable": true,
          "price": {
            "min": 5000,
            "max": 15000
          },
          "deliverables": [
            "Complete PRD.md",
            "User personas",
            "Feature prioritization matrix",
            "Technical architecture document",
            "Integration requirements",
            "Compliance assessment"
          ]
        },
        "design": {
          "type": "full-design-service",
          "source": "design-team-creates",
          "customization": "full",
          "support": "unlimited-revisions-until-approval",
          "billable": true,
          "price": {
            "min": 10000,
            "max": 35000
          },
          "deliverables": [
            "Brand integration",
            "Custom component library",
            "All page designs",
            "Mobile responsive designs",
            "Interactive prototypes",
            "Design system documentation"
          ]
        },
        "patternDefinition": {
          "type": "custom-pattern-creation",
          "source": "new-pattern-definition",
          "customization": "full",
          "support": "architect-review",
          "billable": true,
          "price": {
            "min": 3000,
            "max": 10000
          },
          "deliverables": [
            "Custom pattern-mapping entry",
            "Agent activation chain",
            "Skill requirements",
            "Database schema design",
            "Integration architecture",
            "MASTER_TASKS.md generation"
          ],
          "ipNote": "Pattern becomes Quik Nation IP for future clients"
        },
        "development": {
          "type": "white-glove-implementation",
          "humanOversight": "continuous",
          "revisionRounds": "unlimited",
          "seniorDeveloperReview": true
        }
      },

      "pricing": {
        "model": "itemized-with-scope",
        "components": {
          "discovery": {
            "min": 5000,
            "max": 15000,
            "note": "Billed upfront before work begins"
          },
          "design": {
            "min": 10000,
            "max": 35000,
            "note": "50% upfront, 50% on approval"
          },
          "patternDefinition": {
            "min": 3000,
            "max": 10000,
            "note": "Included in discovery for most projects"
          },
          "development": {
            "min": 50000,
            "max": 150000,
            "note": "Milestone-based payments"
          }
        },
        "totalRange": {
          "min": 68000,
          "max": 210000
        }
      },

      "recurring": {
        "hosting": {
          "min": 499,
          "max": 999,
          "period": "monthly"
        },
        "support": {
          "min": 499,
          "max": 999,
          "period": "monthly",
          "note": "Dedicated support with SLA, includes monthly check-ins"
        },
        "transactionFees": {
          "percentage": 0.25,
          "note": "Reduced platform fee for premium clients"
        },
        "retainer": {
          "min": 2000,
          "max": 5000,
          "period": "monthly",
          "note": "Optional ongoing development retainer"
        }
      },

      "requirements": {
        "clientProvides": [
          "Access to stakeholders for discovery",
          "Business documentation (if exists)",
          "Brand assets (or budget for brand creation)",
          "Content (or content creation budget)",
          "Stripe account (we help set up if needed)",
          "Domain name",
          "Dedicated point of contact"
        ],
        "quikNationProvides": [
          "Full discovery process",
          "Complete PRD creation",
          "Custom design creation",
          "Custom pattern definition",
          "White-glove implementation",
          "AWS infrastructure with optimization",
          "Deployment with monitoring",
          "90-day bug fixes",
          "Training sessions (up to 3)",
          "Documentation",
          "Launch support"
        ]
      }
    },

    "enterprise": {
      "displayName": "Enterprise",
      "description": "Multi-application, multi-team, ongoing partnership",
      "targetClient": "Large organizations, multiple projects, ongoing development",
      "deliveryTime": "Custom timeline per project",

      "included": {
        "all": "Everything in Full Custom",
        "additional": [
          "Dedicated account manager",
          "Multi-project management",
          "Custom SLA",
          "On-site workshops (optional)",
          "Priority access to new features",
          "Custom integration development",
          "White-label options"
        ]
      },

      "pricing": {
        "model": "custom-contract",
        "minimumAnnualCommitment": 250000,
        "note": "Custom pricing based on scope and volume"
      },

      "recurring": {
        "model": "custom-msa",
        "note": "Master Service Agreement with custom terms"
      }
    }
  },

  "addOnServices": {
