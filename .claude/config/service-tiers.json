        },
        "enterpriseIntegration": {
          "price": 15000,
          "includes": ["Enterprise system integration", "SSO", "Custom middleware", "Full support"]
        }
      }
    },

    "expeditedDelivery": {
      "displayName": "Expedited Delivery",
      "description": "Faster delivery timeline",
      "availability": ["self-service", "guided-custom"],
      "pricing": {
        "model": "percentage-upcharge",
        "twoWeeksFaster": 25,
        "fourWeeksFaster": 50,
        "note": "Percentage added to base development cost"
