{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window loading remote claracode.ai (or localhost in dev)",
  "windows": ["main"],
  "permissions": ["core:default"],
  "remote": {
    "urls": [
      "https://claracode.ai/*",
      "https://*.claracode.ai/*",
      "http://localhost:*/*",
      "http://127.0.0.1:*/*"
    ]
  }
}
