{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clara Code",
  "version": "0.1.0",
  "identifier": "ai.claracode.desktop",
  "build": {
    "beforeDevCommand": "npm run build:voice-overlay",
    "beforeBuildCommand": "npm run build:voice-overlay",
    "devUrl": "http://localhost:3000",
    "frontendDist": "https://claracode.ai"
  },
  "app": {
    "withGlobalTauri": false,
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray-icon.png",
      "tooltip": "Clara Code",
      "showMenuOnLeftClick": true
    },
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "Clara Code",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "center": true,
        "decorations": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "http": {
      "scope": [
        "https://info-24346--clara-voice-server-voiceserver-fastapi-app.modal.run/*"
      ]
    }
  }
}
