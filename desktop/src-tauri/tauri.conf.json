{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clara Code",
  "version": "0.1.0",
  "identifier": "ai.claracode.desktop",
  "build": {
    "beforeDevCommand": "npm run build:voice-overlay && npm run build:shell-voice && npm run shell:serve",
    "beforeBuildCommand": "npm run build:voice-overlay && npm run build:shell-voice",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../shell"
  },
  "app": {
    "withGlobalTauri": false,
    "trayIcon": {
      "id": "main",
      "iconPath": "icons/tray-icon.png",
      "tooltip": "Clara Code",
      "showMenuOnLeftClick": true
    },
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "Clara Code",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "center": true,
        "decorations": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "http": {
      "scope": ["https://**"]
    }
  }
}
