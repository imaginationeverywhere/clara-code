{
	"name": "clara",
	"version": "0.2.2",
	"description": "Clara Code terminal voice interface (npm install -g clara@latest)",
	"type": "module",
	"bin": {
		"clara": "./dist/index.js"
	},
	"files": ["dist", ".claude", "mcp-brain-customer.example.json"],
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/imaginationeverywhere/clara-code.git",
		"directory": "packages/cli"
	},
	"scripts": {
		"dev": "tsx src/index.ts",
		"prebuild": "npm run build -w @clara/clara-code-surface-scripts",
		"build": "tsup --config tsup.config.ts",
		"tui": "tsx src/index.ts tui",
		"typecheck": "tsc --noEmit",
		"check": "tsc --noEmit",
		"test": "node --test --import tsx test/*.test.ts test/lib/*.test.ts"
	},
	"dependencies": {
		"@imaginationeverywhere/clara-voice-client": "workspace:*",
		"commander": "^13.1.0",
		"keytar": "^7.9.0",
		"prompts": "^2.4.2",
		"ink": "^6.8.0",
		"react": "^19.2.0"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@types/prompts": "^2.4.9",
		"@types/node": "^22.10.5",
		"@types/react": "^19.0.0",
		"tsup": "^8.0.0",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2"
	}
}
