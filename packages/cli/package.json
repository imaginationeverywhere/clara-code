{
	"name": "@imaginationeverywhere/clara-cli",
	"version": "0.66.1",
	"description": "Clara Code command-line interface",
	"type": "module",
	"bin": {
		"clara": "./dist/index.js"
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json",
		"dev": "tsgo -p tsconfig.build.json --watch --preserveWatchOutput",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"keywords": [
		"clara",
		"cli",
		"ai"
	],
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/badlogic/pi-mono.git",
		"directory": "packages/cli"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {
		"commander": "^13.1.0",
		"ink": "^5.0.1",
		"react": "^19.0.0"
	},
	"devDependencies": {
		"@types/react": "^19.0.0",
		"@types/node": "^22.10.5",
		"shx": "^0.4.0",
		"typescript": "^5.9.2"
	}
}
