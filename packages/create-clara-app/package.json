{
	"name": "create-clara-app",
	"version": "0.1.2",
	"description": "Scaffold a Next.js 15 app with Clara, Clerk, and Cloudflare (OpenNext)",
	"type": "module",
	"bin": {
		"create-clara-app": "./bin/index.js"
	},
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && shx chmod +x bin/index.js",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"files": [
		"bin",
		"dist",
		"templates"
	],
	"keywords": [
		"ai",
		"agent",
		"clara",
		"claracode",
		"create",
		"nextjs",
		"cloudflare"
	],
	"author": "Imagination Everywhere",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/imaginationeverywhere/clara-code.git",
		"directory": "packages/create-clara-app"
	},
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"dependencies": {},
	"devDependencies": {
		"@types/node": "^22.10.5",
		"shx": "^0.4.0",
		"typescript": "^5.9.2"
	}
}
