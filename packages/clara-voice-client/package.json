{
	"name": "@imaginationeverywhere/clara-voice-client",
	"version": "0.1.0",
	"description": "Shared client for quikvoice /voice/converse, greeting cache, and offline-safe voice helpers (CLI, desktop, web).",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": ["dist", "README.md", "CHANGELOG.md"],
	"scripts": {
		"build": "tsup --config tsup.config.ts",
		"check": "tsc --noEmit -p tsconfig.json",
		"test": "node --test --import tsx test/*.test.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/imaginationeverywhere/clara-code.git",
		"directory": "packages/clara-voice-client"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.5",
		"tsup": "^8.0.0",
		"tsx": "^4.20.3",
		"typescript": "^5.9.2"
	}
}
