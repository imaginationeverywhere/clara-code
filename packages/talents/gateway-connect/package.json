{
	"name": "@claracode/talent-gateway-connect",
	"version": "1.0.0",
	"description": "Baseline Clara gateway integration Talent",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"scripts": {
		"build": "tsup src/server.ts src/index.ts --format cjs --clean --external @claracode/marketplace-sdk",
		"start": "node dist/server.js",
		"dev": "ts-node src/server.ts",
		"test": "jest",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@apollo/server": "^4.12.2",
		"@apollo/subgraph": "^2.13.3",
		"@claracode/marketplace-sdk": "workspace:*",
		"body-parser": "^1.20.3",
		"express": "^4.21.2",
		"graphql": "^16.11.0",
		"graphql-tag": "^2.12.6"
	},
	"devDependencies": {
		"@types/body-parser": "^1.19.5",
		"@types/express": "^4.17.21",
		"@types/jest": "^29.5.14",
		"@types/supertest": "^6.0.2",
		"jest": "^29.7.0",
		"supertest": "^7.0.0",
		"ts-jest": "^29.3.4",
		"ts-node": "^10.9.2",
		"tsup": "^8.3.5",
		"typescript": "^5.9.2"
	},
	"publishConfig": {
		"registry": "https://registry.claracode.ai"
	}
}
