# Slack (required for mom bot)
# MOM_SLACK_APP_TOKEN=
# MOM_SLACK_BOT_TOKEN=

# Optional: Clara Gateway (Hermes). When set, mom probes reachability on startup and may route via Hermes.
# Use your deployment URL (e.g. from SSM /quik-nation/shared/CLARA_GATEWAY_URL), not a committed default.
# HERMES_GATEWAY_URL=
