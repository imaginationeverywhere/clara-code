{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ES2020",
		"moduleResolution": "bundler",
		"lib": ["ES2020", "DOM"],
		"outDir": "dist/webview",
		"rootDir": "src/webview",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"jsx": "react-jsx"
	},
	"include": ["src/webview/**/*.ts", "src/webview/**/*.tsx", "src/webview/**/*.d.ts"],
	"exclude": ["node_modules"]
}
