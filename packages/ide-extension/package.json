{
	"name": "clara-code",
	"displayName": "Clara Code",
	"description": "AI voice coding assistant powered by Clara",
	"version": "0.1.0",
	"publisher": "imaginationeverywhere",
	"engines": {
		"vscode": "^1.85.0"
	},
	"categories": ["AI", "Programming Languages", "Other"],
	"icon": "assets/icon.png",
	"activationEvents": ["onStartupFinished"],
	"main": "./dist/extension.js",
	"contributes": {
		"viewsContainers": {
			"activitybar": [
				{
					"id": "clara-sidebar",
					"title": "Clara",
					"icon": "assets/clara-icon.svg"
				}
			]
		},
		"views": {
			"clara-sidebar": [
				{
					"type": "webview",
					"id": "clara.panel",
					"name": "Clara Voice",
					"retainContextWhenHidden": true
				},
				{
					"id": "clara.agentTray",
					"name": "Agents"
				}
			]
		},
		"commands": [
			{
				"command": "clara.setGatewayUrl",
				"title": "Clara: Set Gateway URL (Dev)",
				"category": "Clara"
			},
			{
				"command": "clara.start",
				"title": "Clara: Open Panel",
				"icon": "$(comment-discussion)"
			},
			{
				"command": "clara.voice",
				"title": "Clara: Toggle Voice",
				"icon": "$(mic)"
			},
			{
				"command": "clara.explain",
				"title": "Clara: Explain Selection"
			},
			{
				"command": "clara.doctor",
				"title": "Clara: Doctor",
				"category": "Clara"
			},
			{
				"command": "clara.login",
				"title": "Clara: Login",
				"category": "Clara"
			},
			{
				"command": "clara.newAgent",
				"title": "Clara: New Agent",
				"category": "Clara"
			},
			{
				"command": "clara.runDeploy",
				"title": "Clara: Deploy (workspace folder name)",
				"category": "Clara"
			},
			{
				"command": "clara.askInline",
				"title": "Clara: Ask Inline (think)",
				"category": "Clara"
			},
			{
				"command": "clara.askGranville",
				"title": "Clara: Ask Granville",
				"category": "Clara"
			},
			{
				"command": "clara.refreshAgents",
				"title": "Clara: Refresh agent list",
				"category": "Clara"
			},
			{
				"command": "clara.openPricing",
				"title": "Clara: Open pricing (upgrade)",
				"category": "Clara"
			}
		],
		"menus": {
			"commandPalette": [
				{
					"command": "clara.setGatewayUrl",
					"when": "false"
				}
			]
		},
		"keybindings": [
			{
				"command": "clara.voice",
				"key": "ctrl+shift+space",
				"mac": "cmd+shift+space"
			},
			{
				"command": "clara.explain",
				"key": "ctrl+shift+e",
				"mac": "cmd+shift+e",
				"when": "editorHasSelection"
			},
			{
				"command": "clara.askInline",
				"key": "ctrl+l",
				"mac": "cmd+l",
				"when": "editorTextFocus"
			}
		],
		"configuration": {
			"title": "Clara Code",
			"properties": {
				"claraCode.userId": {
					"type": "string",
					"default": "dev",
					"description": "Display name / user id sent to the gateway (non-secret)"
				},
				"claraCode.panelMode": {
					"type": "boolean",
					"default": false,
					"description": "Use 280px terminal-panel register (surface: panel) — ultra-short copy"
				}
			}
		}
	},
	"scripts": {
		"precompile": "npm run build -w @clara/clara-code-surface-scripts",
		"compile": "webpack --mode development",
		"build": "webpack --mode production",
		"watch": "webpack --mode development --watch",
		"package": "vsce package",
		"lint": "eslint src --ext ts,tsx",
		"check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.webview.json"
	},
	"devDependencies": {
		"@types/react": "^18.3.0",
		"@types/react-dom": "^18.3.0",
		"@types/vscode": "^1.85.0",
		"@typescript-eslint/eslint-plugin": "^6.21.0",
		"@typescript-eslint/parser": "^6.21.0",
		"@vscode/vsce": "^2.22.0",
		"css-loader": "^6.11.0",
		"eslint": "^8.57.0",
		"style-loader": "^3.3.0",
		"ts-loader": "^9.5.0",
		"typescript": "^5.9.2",
		"webpack": "^5.0.0",
		"webpack-cli": "^5.0.0"
	},
	"dependencies": {
		"@clara/clara-code-surface-scripts": "file:../clara-code-surface-scripts",
		"react": "^18.3.0",
		"react-dom": "^18.3.0"
	}
}
