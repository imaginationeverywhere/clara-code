{
	"compilerOptions": {
		"target": "ES2020",
		"module": "commonjs",
		"lib": ["ES2020"],
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"declaration": true,
		"sourceMap": true
	},
	"include": ["src/extension.ts", "src/commands/**/*.ts", "src/ClaraPanelProvider.ts"],
	"exclude": ["node_modules", "src/webview"]
}
