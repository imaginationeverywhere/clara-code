# Copy to .env for local development (never commit real secrets)

# Stripe — dynamic pricing, no price ID env vars
# Stripe merchant keys are in AWS SSM: /clara-code/STRIPE_SECRET_KEY
# Wrangler secret: STRIPE_SECRET_KEY (set via: wrangler secret put STRIPE_SECRET_KEY)
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret — from Stripe Dashboard → Webhooks → your endpoint → Signing secret
# For local testing: stripe listen --forward-to localhost:3001/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_...

# ❌ DO NOT ADD: STRIPE_PRICE_PRO or STRIPE_PRICE_BUSINESS
# Clara Code uses dynamic pricing. Prices are resolved via stripe.prices.list()
# with metadata clara_tier=pro or clara_tier=business.
# Set clara_tier metadata on your Stripe prices in the dashboard.

# Clara Voice Service — set to your deployed voice endpoint (no hardcoded URL in app code)
# Retrieve from AWS SSM: aws ssm get-parameter --name '/clara-code/CLARA_VOICE_URL' --with-decryption
CLARA_VOICE_URL=https://your-voice-endpoint.example.com

# Hermes Gateway — Modal-hosted Whisper + XTTS behind cp-team's clara-voice-server.
# Populated by cp-team in SSM: /clara-code/HERMES_GATEWAY_URL (String).
# Backend proxies /api/voice/stt → $HERMES_GATEWAY_URL/voice/stt
# and /api/voice/tts → $HERMES_GATEWAY_URL/voice/tts.
# When unset, the two routes fall back to CLARA_VOICE_URL, and respond 503 if neither is set.
# HERMES_GATEWAY_URL=https://info-24346--clara-voice-server-voiceserver-fastapi-app.modal.run

# Hermes internal API key — swapped in by this service as `Authorization: Bearer $HERMES_API_KEY`
# on Modal calls (Option B auth scheme, see docs/clara-platform/voice-auth-scheme.md).
# User auth: the CLI/web client sends a Clerk JWT or sk-clara- key to this service, we validate it,
# then substitute the internal HERMES_API_KEY before forwarding to Modal. Modal never sees user tokens.
# Populated by cp-team in SSM: /clara-code/HERMES_API_KEY (SecureString).
# Real mode requires BOTH HERMES_GATEWAY_URL and HERMES_API_KEY — missing key = 503.
# HERMES_API_KEY=...

# Heads up for sprint demos: Modal A10G GPU scales to zero. First request after idle loads
# Whisper + XTTS (60–120s). The CLI shows "warming up…" when it takes >4s, but pre-warming
# the container ~2 minutes before a demo is the safe play.

# Voice dev stub — set to "1" to bypass Modal entirely for local CLI development.
# /api/voice/stt returns a mock transcript (from `x-clara-stub-text` header, body.stubText, or default).
# /api/voice/tts returns a 1-second silence WAV so the CLI can exercise its audio plumbing
# without making any external call. NEVER set this in production.
# CLARA_VOICE_DEV_STUB=1

# Clerk — backend API (REST user lookup, webhooks). Publishable key is frontend-only.
# CLERK_SECRET_KEY=sk_live_...

# Clerk webhooks — Svix signing secret from Clerk Dashboard → Webhooks → Endpoint → Signing Secret
# Endpoint URL: https://<your-api-host>/api/webhooks/clerk
# CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# AWS SES — transactional email (welcome, first API key). In ECS, credentials come from the task role.
# AWS_REGION=us-east-1
# CLARA_EMAIL_FROM=noreply@claracode.ai
