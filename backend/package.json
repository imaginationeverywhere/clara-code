    "@aws-sdk/client-s3": "^3.832.0",
    "@aws-sdk/client-ses": "^3.832.0",
    "@aws-sdk/client-sns": "^3.832.0",
    "@aws-sdk/client-ssm": "^3.734.0",
    "@aws-sdk/s3-request-presigner": "^3.832.0",
    "@clerk/backend": "^2.4.0",
    "@clerk/express": "^1.7.62",
    "@graphql-tools/graphql-file-loader": "^8.0.20",
    "@graphql-tools/load": "^8.1.0",
    "@graphql-tools/load-files": "^7.0.0",
    "@graphql-tools/merge": "^9.0.0",
    "@sendgrid/mail": "^8.1.3",
