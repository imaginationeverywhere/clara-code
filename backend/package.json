{
  "name": "@clara-code/backend",
  "version": "1.0.2",
  "description": "Clara Code API — Express, Apollo GraphQL, Clerk, Neon Postgres",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:seed:talents": "ts-node scripts/seed-first-party-talents.ts",
    "db:reset": "sequelize-cli db:migrate:undo:all && npm run db:migrate",
    "test": "jest",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@apollo/server": "^4.12.2",
