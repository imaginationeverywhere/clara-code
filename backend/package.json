    "nodemailer": "^6.9.7",
    "pg": "^8.16.0",
    "pg-hstore": "^2.3.4",
    "prettier": "^3.5.3",
    "rate-limit-redis": "^4.3.1",
    "redis": "^4.6.11",
    "reflect-metadata": "^0.2.2",
    "sequelize": "^6.35.0",
    "sequelize-typescript": "^2.1.6",
    "sharp": "^0.34.2",
    "stripe": "^14.7.0",
    "svix": "^1.89.0",
    "ts-node-dev": "^2.0.0",
